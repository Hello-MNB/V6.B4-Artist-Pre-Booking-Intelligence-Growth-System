# ─────────────────────────────────────────────────────────────
# GIGPROOF — local environment. Copy this file to ".env.local"
# and fill in the values. .env.local is git-ignored (never committed).
# ─────────────────────────────────────────────────────────────

# ── Supabase (free cloud project: https://supabase.com → New project) ──
# Project Settings → API → Project URL  and  anon/public key
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Server-side only (used by server/index.js, NEVER exposed to browser) ──
# Supabase service_role key (Project Settings → API). Lets the AI server
# write Claim records past RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (Claude) — for AI evidence→claim processing ──
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
# Model used for claim extraction/labelling
ANTHROPIC_MODEL=claude-opus-4-8

# Local AI/api server port (must match vite proxy)
API_PORT=8787

# ── Gate email (§14.6.5) — DARK BY DEFAULT (rule 11: never sends in dev/test) ──
# The availability-request ("someone asked about your date") email to the artist
# sends ONLY when BOTH are set: EMAIL_ENABLED=1 AND a real RESEND_API_KEY.
# Leave EMAIL_ENABLED unset/0 everywhere until the owner flips it in production.
EMAIL_ENABLED=0
# Resend API key (https://resend.com) — server-side only, never exposed to browser.
RESEND_API_KEY=
# Optional FROM override. Default in code: 'LOCK <hello@lock.show>' (brief W3-5);
# spec §14.6.5 authors 'LOCK <notifications@lock.show>' — set EMAIL_FROM to the
# owner-confirmed address at wiring time.
EMAIL_FROM=

# ── Social login (Google/Facebook via Supabase Auth) — OFF by default ──
# Flip to 1 only after both providers are configured in Supabase Dashboard →
# Authentication → Providers (see SOCIAL-LOGIN-SETUP for the full walkthrough).
VITE_OAUTH_ENABLED=0
